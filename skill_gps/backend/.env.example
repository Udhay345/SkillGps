# Skill GPS Backend — Environment Variables
# ──────────────────────────────────────────
# Copy this file to `.env` and fill in your own keys.
# NEVER commit the real `.env` file to Git!

# ── Google Gemini API Key ─────────────────
# Get a free key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Groq API Key ──────────────────────────
# Fast, free AI inference. Get your key at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# ── Email (SMTP) Configuration ────────────
# Used for sending notifications. Works with Gmail App Passwords.
# Enable 2FA on your Gmail, then generate an App Password:
# https://myaccount.google.com/apppasswords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=465
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password_here

# ── Server Port (optional) ────────────────
# Defaults to 5000 if not set.
PORT=5000
